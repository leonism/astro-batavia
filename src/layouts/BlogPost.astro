---
import type { CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import BlogNextPrevNavigation from '@/components/blog/BlogPrevNextNavigation.astro';
import BlogShareButtons from '@/components/blog/BlogShareButtons.astro';
import BlogRelatedArticles from '@/components/blog/BlogRelatedArticles.astro';
import BlogTableOfContents from '@/components/blog/BlogTableOfContents.astro';
import BlogPostMeta from '@/components/blog/BlogPostMeta.astro';
import BlogPostTags from '@/components/blog/BlogPostTags.astro';
import BlogPostHero from '@/components/blog/BlogPostHero.astro';
import { SITE_TITLE, SITE_URL, SOCIAL_LINKS } from '@/consts';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { BlogService } from '@/services/BlogService';
import { getEntry } from 'astro:content';

type BlogFrontmatter = CollectionEntry<'blog'>['data'];

export interface Props extends BlogFrontmatter {
  slug: string;
  readingTime?: string;
  readingTimeMinutes?: number;
  headings: { depth: number; slug: string; text: string }[];
}

const {
  title,
  description,
  pubDate,
  editDate: updatedDate,
  heroImage,
  heroImageAlt,
  author,
  authorURL,
  tags,
  slug,
  readingTime,
  readingTimeMinutes,
  headings,
  faqs,
  review,
  license,
  acquireLicensePage,
  creditText,
  copyrightNotice,
  creator,
} = Astro.props as Props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const allLangPosts = await BlogService.getPostsByLocale(lang);
const { previousPost, nextPost } = BlogService.getPostNavigation(allLangPosts, slug);
const relatedPosts = BlogService.getRelatedPosts(allLangPosts, slug, tags);

// Resolve author sameAs links from authors collection
let authorSameAs: string[] = [];
if (author) {
  const authorEntry = await BlogService.getAuthorDetails(author);
  if (authorEntry) {
    authorSameAs = authorEntry.data.sameAs || [];
  }
}
---

<Layout
  title={title}
  description={description}
  image={heroImage}
  imageAlt={heroImageAlt}
  lang={lang}
  type="blog"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
  author={author}
  authorUrl={authorURL}
  authorSameAs={authorSameAs}
  articleDate={pubDate}
  tags={tags || []}
  readingTime={readingTime ? parseInt(readingTime.replace(/\D/g, '')) : undefined}
  excerpt={description}
  headings={headings}
  breadcrumbs={[
    { name: t('nav.home'), url: new URL(getLocalizedPath('/', lang), Astro.site).href },
    { name: t('nav.blog'), url: new URL(getLocalizedPath('/blog', lang), Astro.site).href },
    { name: title, url: Astro.url.href },
  ]}
  organization={{
    name: SITE_TITLE,
    url: SITE_URL,
    logo: new URL('/favicon.svg', SITE_URL).href,
    sameAs: [SOCIAL_LINKS.github, SOCIAL_LINKS.X, SOCIAL_LINKS.linkedin],
  }}
  faqs={faqs}
  review={review}
  license={license}
  acquireLicensePage={acquireLicensePage}
  creditText={creditText}
  copyrightNotice={copyrightNotice}
  creator={creator}
>
  <main id="main-content">
    {/* 2-column grid on desktop: [TOC sidebar | article content] */}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div
        class={`relative ${headings.length > 0 ? 'lg:grid lg:grid-cols-[1fr_220px] lg:gap-10 xl:grid-cols-[1fr_240px] xl:gap-12' : ''}`}
      >
        {/* ── Main article (left) ── */}
        <article role="article" class="min-w-0 py-8">
          {/* Article header */}
          <header class="mb-8">
            <BlogPostHero {heroImage} {heroImageAlt} {title} />
            <div class="space-y-6">
              <BlogPostTags tags={tags || []} {lang} />
              <BlogPostMeta
                {author}
                {pubDate}
                {updatedDate}
                {readingTime}
                {readingTimeMinutes}
                {lang}
                {t}
              />
            </div>
          </header>

          {/* Article content */}
          <div class="prose prose-base max-w-none dark:prose-invert">
            <slot />
          </div>

          {/* Footer elements */}
          <BlogShareButtons {title} url={Astro.url.href} />
          <BlogNextPrevNavigation previousPostData={previousPost} nextPostData={nextPost} {lang} />
          <BlogRelatedArticles {relatedPosts} {lang} />
        </article>

        {/* ── Right sidebar: sticky TOC (desktop only) ── */}
        {headings.length > 0 && <BlogTableOfContents {headings} {lang} variant="sidebar" />}
      </div>
    </div>
  </main>
</Layout>

<script>
  /**
   * Code Copy Button Logic
   */
  const initCopyButtons = () => {
    const codeBlocks = document.querySelectorAll('pre.astro-code');

    codeBlocks.forEach((block) => {
      // 1. Avoid duplicate buttons on re-init
      if (block.querySelector('.copy-code-button')) return;

      // 2. Ensure the block is a hover group
      block.classList.add('group');

      // 3. Create the copy button
      const button = document.createElement('button');
      button.className = 'copy-code-button';
      button.type = 'button';
      button.ariaLabel = 'Copy code to clipboard';
      button.innerHTML = `
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      `;

      // 4. Add click event handler
      button.addEventListener('click', async () => {
        const codeText = block.querySelector('code')?.innerText || block.textContent || '';

        try {
          await navigator.clipboard.writeText(codeText);

          // Success feedback
          button.classList.add('copied');
          button.innerHTML = `
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          `;

          // Reset feedback after 2 seconds
          setTimeout(() => {
            button.classList.remove('copied');
            button.innerHTML = `
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            `;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });

      // 5. Append button to the code block
      block.appendChild(button);
    });
  };

  // Run on page load and after Astro View Transitions
  document.addEventListener('astro:page-load', initCopyButtons);
</script>
