---
import { TypographyH1, TypographyLead } from '@/components/ui/typography';
import { useTranslations, getLocalizedPath } from '@/i18n/utils';
import type { LanguageKey } from '@/i18n/types';

interface Props {
  lang: LanguageKey;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const title = `${t('home.hero.mainTitle')}`;
const subtitle = t('home.hero.description');

const cta1Text = t('home.hero.startReading');
const cta1Link = getLocalizedPath('/blog/', lang);
const cta2Text = t('home.hero.exploreContent');
const cta2Link = getLocalizedPath('/search/', lang);
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-slate-50 dark:bg-slate-900"
>
  <!-- Grid Background -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 h-full w-full bg-[linear-gradient(to_right,var(--hero-grid-color)_1px,transparent_1px),linear-gradient(to_bottom,var(--hero-grid-color)_1px,transparent_1px)] bg-size-[40px_40px] mask-[radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
    <div class="space-y-6">
      <TypographyH1
        class="text-5xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-6xl lg:text-7xl xl:text-8xl"
        set:html={title}
      />
      <TypographyLead
        class="mx-auto max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-300 sm:text-xl"
        set:html={subtitle}
      />
    </div>

    <div class="flex flex-col items-center justify-center gap-4 pt-12 sm:flex-row md:pt-16">
      <a
        href={cta1Link}
        class="group inline-flex items-center justify-center w-52 h-14 rounded-2xl bg-hero-gradient text-lg font-semibold text-white transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-blue-500/25 focus:outline-none focus:ring-4 focus:ring-blue-500/50"
      >
        <span set:html={cta1Text} />
        <svg
          class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"
          >
          </path>
        </svg>
      </a>
      <a
        href={cta2Link}
        class="group inline-flex items-center justify-center w-52 h-14 rounded-2xl border-2 border-slate-200 bg-white/80 text-lg font-semibold text-slate-700 backdrop-blur-sm transition-all duration-300 hover:scale-105 hover:bg-white dark:border-slate-700 dark:bg-slate-800/80 dark:text-slate-300 dark:hover:bg-slate-800 focus:outline-none focus:ring-4 focus:ring-slate-500/50"
      >
        <span set:html={cta2Text} />
        <svg
          class="ml-2 h-5 w-5 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
          >
          </path>
        </svg>
      </a>
    </div>
  </div>
</section>
