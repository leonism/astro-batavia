---
import { type CollectionEntry, getEntry } from 'astro:content';
import { getLocalizedPath, slugifyTag, useTranslations } from '@/i18n/utils';
import { Image } from 'astro:assets';

import Avatar from '@/components/ui/Avatar.astro';
import { TypographyH3, TypographyMuted } from '@/components/ui/typography';

interface Props extends HTMLAttributes<'a'> {
  authorName: string;
  lang: string;
  postCount: number;
}

import { BlogService } from '@/services/BlogService';

const { authorName, lang, postCount, class: className, ...rest } = Astro.props;

// Try to get more details from the authors collection
const authorDetails = await BlogService.getAuthorDetails(authorName);
const authorSlug = slugifyTag(authorName);

const authorUrl = getLocalizedPath(`/blog/authors/${authorSlug}`, lang);
const t = useTranslations(lang as any);
---

<a
  href={authorUrl}
  class:list={[
    'group relative flex flex-col items-center overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:border-blue-500 hover:shadow-xl dark:border-slate-800 dark:bg-slate-900/50 dark:hover:border-blue-400',
    className,
  ]}
  {...rest}
>
  {/* Avatar */}
  <div class="mb-6 relative">
    <div
      class="absolute -inset-1 rounded-full bg-linear-to-tr from-blue-600 to-purple-600 opacity-0 blur transition duration-300 group-hover:opacity-20"
    >
    </div>
    <Avatar
      src={authorDetails?.data.avatar}
      alt={authorName}
      size="xl"
      class="relative transition duration-300 group-hover:scale-105"
    />
  </div>

  {/* Info */}
  <div class="relative">
    <TypographyH3
      class="mb-1 transition-colors group-hover:text-blue-600 dark:group-hover:text-blue-400"
    >
      {authorName}
    </TypographyH3>
    {
      authorDetails?.data.role && (
        <TypographyMuted class="mb-3 font-medium">
          {authorDetails.data.role}
        </TypographyMuted>
      )
    }

    <div class="flex items-center justify-center gap-2">
      <span
        class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-400"
      >
        {postCount}
        {postCount === 1 ? t('blog.post') : t('blog.posts')}
      </span>
    </div>

    {
      authorDetails?.data.bio && (
        <p class="mt-4 line-clamp-2 text-sm text-slate-600 dark:text-slate-400">
          {authorDetails.data.bio}
        </p>
      )
    }
  </div>

  {/* Decor */}
  <div
    class="absolute right-4 top-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-5 w-5 text-blue-500"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 8l4 4m0 0l-4 4m4-4H3"
      >
      </path>
    </svg>
  </div>
</a>
