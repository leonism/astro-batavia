---
import { type CollectionEntry, getEntry } from 'astro:content';
import { getLocalizedPath, slugifyTag, useTranslations } from '@/i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  authorName: string;
  lang: string;
  postCount: number;
}

const { authorName, lang, postCount } = Astro.props;

// Try to get more details from the authors collection
let authorDetails: CollectionEntry<'authors'> | null = null;
const authorSlug = slugifyTag(authorName);

try {
  authorDetails = await getEntry('authors', authorSlug);
} catch (e) {
  // Ignore if not found
}

const authorUrl = getLocalizedPath(`/blog/authors/${authorSlug}`, lang);
const t = useTranslations(lang as any);
---

<a 
  href={authorUrl}
  class="group relative flex flex-col items-center overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:border-blue-500 hover:shadow-xl dark:border-slate-800 dark:bg-slate-900/50 dark:hover:border-blue-400"
>
  {/* Avatar or Initial */}
  <div class="mb-6 relative">
    <div class="absolute -inset-1 rounded-full bg-gradient-to-tr from-blue-600 to-purple-600 opacity-0 blur transition duration-300 group-hover:opacity-20"></div>
    {authorDetails?.data.avatar ? (
      <img 
        src={authorDetails.data.avatar} 
        alt={authorName}
        class="relative h-24 w-24 rounded-full object-cover ring-2 ring-slate-100 transition duration-300 group-hover:ring-blue-500 dark:ring-slate-800"
      />
    ) : (
      <div class="relative flex h-24 w-24 items-center justify-center rounded-full bg-blue-100 text-3xl font-bold text-blue-600 ring-2 ring-slate-100 transition duration-300 group-hover:ring-blue-500 dark:bg-blue-900/30 dark:text-blue-400 dark:ring-slate-800">
        {authorName.charAt(0)}
      </div>
    )}
  </div>

  {/* Info */}
  <div class="relative">
    <h3 class="mb-1 text-xl font-bold text-slate-900 transition-colors group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400">
      {authorName}
    </h3>
    {authorDetails?.data.role && (
      <p class="mb-3 text-sm font-medium text-slate-500 dark:text-slate-400">
        {authorDetails.data.role}
      </p>
    )}
    
    <div class="flex items-center justify-center gap-2">
      <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-400">
        {postCount} {postCount === 1 ? t('blog.post') : t('blog.posts')}
      </span>
    </div>

    {authorDetails?.data.bio && (
      <p class="mt-4 line-clamp-2 text-sm text-slate-600 dark:text-slate-400">
        {authorDetails.data.bio}
      </p>
    )}
  </div>

  {/* Decor */}
  <div class="absolute right-4 top-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </div>
</a>
