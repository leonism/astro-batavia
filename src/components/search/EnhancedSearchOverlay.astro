---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import SearchOverlayInput from '@/components/search/SearchOverlayInput.astro';
import SearchOverlaySuggestions from '@/components/search/SearchOverlaySuggestions.astro';
import SearchOverlayResults from '@/components/search/SearchOverlayResults.astro';
import SearchOverlayNoResults from '@/components/search/SearchOverlayNoResults.astro';
import SearchOverlayFooter from '@/components/search/SearchOverlayFooter.astro';
import type { LanguageKey } from '@/i18n/types';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang as any);
---

<section
  id="search-overlay"
  class="fixed inset-0 z-100 hidden bg-white/95 p-4 backdrop-blur-xl dark:bg-slate-900/95"
  aria-labelledby="search-overlay-title"
  role="search"
  aria-hidden="true"
>
  <h2 id="search-overlay-title" class="sr-only">Search</h2>

  <button
    id="close-search-overlay"
    class="absolute right-4 top-4 z-10 text-gray-600 transition-colors duration-200 hover:text-primary-600 dark:text-gray-300 dark:hover:text-primary-400"
    aria-label="Close search"
  >
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"
      >
      </path>
    </svg>
  </button>

  <div class="mx-auto w-full max-w-4xl">
    <SearchOverlayInput />
    <SearchOverlaySuggestions />
    <SearchOverlayResults />
    <SearchOverlayNoResults />
    <SearchOverlayFooter />
  </div>
</section>

<script>
  import { EnhancedSearchUI } from '@/features/search/EnhancedSearchUI';
  new EnhancedSearchUI();
</script>


