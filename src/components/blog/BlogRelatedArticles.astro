---
import { useTranslations } from '@/i18n/utils';
import type { CollectionEntry } from 'astro:content';
import { ui } from '@/i18n/ui';
import BlogCard from '@/components/blog/BlogCard.astro';

interface Props {
  relatedPosts: CollectionEntry<'blog'>[];
  lang: keyof typeof ui;
}

const { relatedPosts, lang } = Astro.props;
const t = useTranslations(lang);
---

{
  relatedPosts.length > 0 && (
    <section class="mt-12 border-t border-gray-200 pt-8 dark:border-gray-700">
      <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-gray-100">
        {t('blog.relatedPosts')}
      </h2>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {relatedPosts.map((post) => (
          <BlogCard 
            post={post} 
            lang={lang} 
            class="post-item animate-fade-in"
          />
        ))}
      </div>
    </section>
  )
}
