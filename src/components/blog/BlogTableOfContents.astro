---
import { useTranslations } from '@/i18n/utils';
import type { LanguageKey } from '@/i18n/types';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  lang: LanguageKey;
  /** 'sidebar' = desktop aside only | 'mobile' = mobile accordion only | 'both' = both (default) */
  variant?: 'sidebar' | 'mobile' | 'both';
}

const { headings, lang, variant = 'both' } = Astro.props;
const t = useTranslations(lang);

// Only include h2 and h3 in the TOC
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const showSidebar = variant === 'sidebar' || variant === 'both';
const showMobile = variant === 'mobile' || variant === 'both';
---

{
  tocHeadings.length > 0 && (
    <>
      {/* ── Desktop: sticky right sidebar ── */}
      {showSidebar && (
        <aside
          id="toc-sidebar"
          class="toc-sidebar hidden lg:block font-stretch-semi-expanded"
          aria-label={t('blog.tableOfContents')}
        >
          <div class="sticky top-24 mt-8 max-h-[calc(100vh-7rem)] overflow-y-auto pr-2 [scrollbar-width:thin]">
            <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
              {t('blog.tableOfContents')}
            </p>
            <nav>
              <ul class="space-y-0.5 border-l border-slate-200 dark:border-slate-700/60">
                {tocHeadings.map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      data-toc-link
                      class={`toc-link block py-1 text-xs leading-5 text-slate-500 transition-colors duration-150 hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400 ${
                        heading.depth === 2
                          ? 'pl-3 font-medium'
                          : 'pl-6 font-normal text-slate-400 dark:text-slate-500'
                      }`}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      {/* ── Mobile: collapsible accordion above the content ── */}
      {showMobile && (
        <div class="toc-mobile relative flex items-center lg:hidden">
          <button
            type="button"
            id="toc-mobile-toggle"
            aria-expanded="false"
            aria-controls="toc-mobile-list"
            class="inline-flex h-8 w-8 items-center justify-center rounded-md text-slate-500 transition-colors hover:bg-slate-100 hover:text-primary-600 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-primary-400"
          >
            <span class="sr-only">{t('blog.tableOfContents')}</span>
            <svg
              class="h-5 w-5 shrink-0"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
            </svg>
          </button>

          <nav
            id="toc-mobile-list"
            class="hidden absolute right-0 top-full mt-3 w-64 max-h-[60vh] overflow-y-auto rounded-lg border border-slate-200 bg-white p-4 shadow-xl dark:border-slate-700 dark:bg-slate-900"
          >
            <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
              {t('blog.tableOfContents')}
            </p>
            <ul class="space-y-1 border-l border-slate-200 dark:border-slate-700/60">
              {tocHeadings.map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class={`toc-mobile-link block py-1 text-sm leading-5 text-slate-600 transition-colors duration-150 hover:text-primary-600 dark:text-slate-300 dark:hover:text-primary-400 ${
                      heading.depth === 2
                        ? 'pl-3 font-medium'
                        : 'pl-6 font-normal text-slate-500 dark:text-slate-400'
                    }`}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      )}
    </>
  )
}

<style is:global>
  /* Active link highlight */
  .toc-link.is-active {
    color: var(--color-primary-600, #2563eb);
    border-left: 2px solid var(--color-primary-500, #3b82f6);
    padding-left: calc(0.75rem - 2px); /* compensate for the border */
    font-weight: 600;
  }

  .dark .toc-link.is-active {
    color: var(--color-primary-400, #60a5fa);
    border-left-color: var(--color-primary-400, #60a5fa);
  }

  /* Depth-3 active stays indented */
  .toc-link.is-active[class*='pl-6'] {
    padding-left: calc(1.5rem - 2px);
  }

  /* Thin scrollbar for sidebar */
  .toc-sidebar [scrollbar-width~='thin'] {
    scrollbar-width: thin;
    scrollbar-color: #e2e8f0 transparent;
  }

  .dark .toc-sidebar [scrollbar-width~='thin'] {
    scrollbar-color: #334155 transparent;
  }
</style>

<script>
  const initToc = () => {
    // ── Mobile toggle ──
    const mobileToggle = document.getElementById('toc-mobile-toggle');
    const mobileList = document.getElementById('toc-mobile-list');

    if (mobileToggle && mobileList) {
      // Avoid re-init on SPA navigation
      if (!mobileToggle.dataset.tocInit) {
        mobileToggle.dataset.tocInit = 'true';
        mobileToggle.addEventListener('click', () => {
          const isOpen = mobileToggle.getAttribute('aria-expanded') === 'true';
          mobileToggle.setAttribute('aria-expanded', String(!isOpen));
          mobileList.classList.toggle('hidden', isOpen);
        });

        // Close accordion when a link is tapped on mobile
        mobileList.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            mobileToggle.setAttribute('aria-expanded', 'false');
            mobileList.classList.add('hidden');
          });
        });

        // Close accordion when clicking outside
        document.addEventListener('click', (event) => {
          const isClickInside =
            mobileToggle.contains(event.target as Node) ||
            mobileList.contains(event.target as Node);
          if (!isClickInside && mobileToggle.getAttribute('aria-expanded') === 'true') {
            mobileToggle.setAttribute('aria-expanded', 'false');
            mobileList.classList.add('hidden');
          }
        });
      }
    }

    // ── Active-link tracking via IntersectionObserver ──
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (!tocLinks.length) return;

    const headingEls: Element[] = [];
    tocLinks.forEach((link) => {
      const id = link.getAttribute('href')?.replace('#', '');
      if (id) {
        const el = document.getElementById(id);
        if (el) headingEls.push(el);
      }
    });

    let activeId = '';

    const setActive = (id: string) => {
      if (id === activeId) return;
      activeId = id;
      tocLinks.forEach((link) => {
        const isActive = link.getAttribute('href') === `#${id}`;
        link.classList.toggle('is-active', isActive);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      {
        rootMargin: '-20% 0% -70% 0%',
        threshold: 0,
      },
    );

    headingEls.forEach((el) => observer.observe(el));
  };

  document.addEventListener('astro:page-load', initToc);
</script>
