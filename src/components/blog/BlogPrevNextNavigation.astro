---
import { useTranslations, getPostUrl } from '@/i18n/utils';
import type { LanguageKey } from '@/i18n/types';
import type { CollectionEntry } from 'astro:content';

interface Props {
  previousPostData?: CollectionEntry<'blog'> | null;
  nextPostData?: CollectionEntry<'blog'> | null;
  lang: LanguageKey;
}

const { previousPostData, nextPostData, lang } = Astro.props;
const t = useTranslations(lang);
---

{
  (previousPostData || nextPostData) && (
    <nav
      class="mt-16 border-t border-gray-200 pt-8 dark:border-gray-700"
      aria-label="Blog post navigation"
    >
      <div
        class={`grid gap-6 ${previousPostData && nextPostData ? 'grid-cols-1 md:grid-cols-2' : 'grid-cols-1'}`}
      >
        {previousPostData && (
          <a
            href={getPostUrl(previousPostData.id, lang)}
            title={`${t('blog.previousArticle')}: ${previousPostData.data.title}`}
            class="group flex flex-row items-stretch overflow-hidden rounded-lg border border-gray-200 bg-white transition-all duration-300 hover:scale-[1.02] hover:border-primary-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-800 dark:hover:border-primary-600"
            data-astro-prefetch
          >
            {previousPostData.data.heroImage && (
              <div class="relative w-24 shrink-0 overflow-hidden md:w-32">
                <img
                  src={previousPostData.data.heroImage}
                  loading="lazy"
                  alt={previousPostData.data.heroImageAlt || ''}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
            )}
            <div class="flex flex-col justify-center p-4">
              <div class="mb-2 flex items-center text-sm text-gray-500 dark:text-gray-400">
                <svg
                  class="mr-2 h-4 w-4 transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="m11 17-5-5 5-5m7 10-5-5 5-5"
                  />
                </svg>
                <span class="transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400">
                  {t('blog.previousArticle')}
                </span>
              </div>
              <h3 class="line-clamp-2 text-lg font-semibold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
                {previousPostData.data.title}
              </h3>
            </div>
          </a>
        )}

        {nextPostData && (
          <a
            href={getPostUrl(nextPostData.id, lang)}
            title={`${t('blog.nextArticle')}: ${nextPostData.data.title}`}
            class="group flex flex-row items-stretch justify-between overflow-hidden rounded-lg border border-gray-200 bg-white transition-all duration-300 hover:scale-[1.02] hover:border-primary-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-800 dark:hover:border-primary-600"
            data-astro-prefetch
          >
            <div class="flex flex-col justify-center p-4 text-right">
              <div class="mb-2 flex items-center justify-end text-sm text-gray-500 dark:text-gray-400">
                <span class="transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400">
                  {t('blog.nextArticle')}
                </span>
                <svg
                  class="ml-2 h-4 w-4 transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="m13 17 5-5-5-5M6 17l5-5-5-5"
                  />
                </svg>
              </div>
              <h3 class="line-clamp-2 text-lg font-semibold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
                {nextPostData.data.title}
              </h3>
            </div>
            {nextPostData.data.heroImage && (
              <div class="relative w-24 shrink-0 overflow-hidden md:w-32">
                <img
                  src={nextPostData.data.heroImage}
                  loading="lazy"
                  alt={nextPostData.data.heroImageAlt || ''}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
            )}
          </a>
        )}
      </div>
    </nav>
  )
}
