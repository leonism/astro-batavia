---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, SOCIAL_LINKS } from '@/consts';
import { SEOService } from '@/services/SEOService';
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';

import FaviconLinks from '@/components/seo/FaviconLinks.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  lang?: string;
  type?: 'website' | 'article' | 'blog' | 'profile' | 'collection';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  authorUrl?: string;
  authorImage?: string;
  authorSameAs?: string[];
  tags?: string[];
  category?: string;
  readingTime?: string;
  wordCount?: number;
  excerpt?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  organization?: {
    name: string;
    url: string;
    logo: string;
    sameAs?: string[];
  };
  video?: {
    url: string;
    thumbnail: string;
    duration?: string;
    description?: string;
  };
  prev?: string;
  next?: string;
  faqs?: Array<{ question: string; answer: string }>;
  review?: any;
  license?: string;
  acquireLicensePage?: string;
  creditText?: string;
  copyrightNotice?: string;
  creator?: string;
}

const {
  title,
  description,
  image,
  noindex = false,
  canonical,
  lang = 'en',
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  authorUrl,
  authorImage,
  authorSameAs = [],
  tags = [],
  category,
  readingTime,
  wordCount,
  excerpt,
  breadcrumbs = [],
  organization,
  video,
  prev,
  next,
  faqs = [],
  review,
  license,
  acquireLicensePage,
  creditText,
  copyrightNotice,
  creator,
} = Astro.props;

const siteTitle = SITE_TITLE;
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;
const siteUrl = (Astro.site?.href || SITE_URL).replace(/\/$/, '');
const imageUrl = image ? new URL(image, siteUrl).href : `${siteUrl}/images/og-default.png`;
const canonicalUrl = canonical || Astro.url.href;

// Enhanced meta data
const finalExcerpt = excerpt || description || SITE_DESCRIPTION;
const defaultOrganization = {
  name: SITE_TITLE,
  url: siteUrl,
  logo: `${siteUrl}/images/og-default.png`,
  sameAs: [SOCIAL_LINKS.X, SOCIAL_LINKS.github, SOCIAL_LINKS.linkedin],
};
const orgData = organization || defaultOrganization;

// Language mappings
const hreflangMap = {
  en: 'en-US',
  es: 'es-ES',
  ja: 'ja-JP',
};

const alternateUrls = SEOService.getAlternateUrls(Astro.url.pathname, siteUrl);

// WebPage subtype mapping
const webPageType = type === 'collection' ? 'CollectionPage' : (type === 'profile' ? 'ProfilePage' : 'WebPage');

// Construct the Graph
const graph: any[] = [
  {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: orgData.name,
    url: orgData.url,
    logo: {
      '@type': 'ImageObject',
      url: orgData.logo,
    },
    sameAs: orgData.sameAs || [
      SOCIAL_LINKS.X,
      SOCIAL_LINKS.github,
      SOCIAL_LINKS.linkedin,
      SOCIAL_LINKS.youtube,
      SOCIAL_LINKS.instagram,
      SOCIAL_LINKS.tiktok,
      SOCIAL_LINKS.telegram,
      SOCIAL_LINKS.facebook
    ],
    publishingPrinciples: SEOService.getLocalizedLegalLinks(lang, siteUrl),
    contactPoint: [
      {
        '@type': 'ContactPoint',
        'email': 'contact@astrobatavia.com',
        'contactType': 'customer support'
      }
    ]
  },
  {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    url: siteUrl,
    name: SITE_TITLE,
    publisher: { '@id': `${siteUrl}/#organization` },
    description: SITE_DESCRIPTION,
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${siteUrl}/search/?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@type': 'Blog',
    '@id': `${siteUrl}/blog/#blog`,
    name: `Blog | ${SITE_TITLE}`,
    description: SITE_DESCRIPTION,
    url: `${siteUrl}/blog/`,
    publisher: { '@id': `${siteUrl}/#organization` },
    isPartOf: { '@id': `${siteUrl}/#website` },
    inLanguage: hreflangMap[lang as keyof typeof hreflangMap] || lang,
  },
  {
    '@type': webPageType,
    '@id': `${canonicalUrl}/#webpage`,
    url: canonicalUrl,
    name: fullTitle,
    description: description,
    isPartOf: { '@id': `${siteUrl}/#website` },
    breadcrumb: breadcrumbs.length > 0 ? { '@id': `${canonicalUrl}/#breadcrumb` } : undefined,
  },
];

if (breadcrumbs.length > 0) {
  graph.push({
    '@type': 'BreadcrumbList',
    '@id': `${canonicalUrl}/#breadcrumb`,
    itemListElement: breadcrumbs.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.name,
      item: crumb.url,
    })),
  });
}

if (type === 'article' || type === 'blog') {
  graph.push({
    '@type': type === 'blog' ? 'BlogPosting' : 'Article',
    '@id': `${canonicalUrl}/#article`,
    author: author
      ? {
          '@type': 'Person',
          name: author,
          url: authorUrl,
          sameAs: authorSameAs,
          image: authorImage ? {
            '@type': 'ImageObject',
            url: authorImage,
          } : undefined,
        }
      : { '@id': `${siteUrl}/#organization` },
    headline: title,
    datePublished: publishedTime,
    dateModified: modifiedTime || publishedTime,
    mainEntityOfPage: { '@id': `${canonicalUrl}/#webpage` },
    isPartOf: type === 'blog' ? [{ '@id': `${canonicalUrl}/#webpage` }, { '@id': `${siteUrl}/blog/#blog` }] : { '@id': `${canonicalUrl}/#webpage` },
    image: (license || acquireLicensePage) ? { '@id': `${imageUrl}/#primaryimage` } : {
      '@type': 'ImageObject',
      url: imageUrl,
    },
    publisher: { '@id': `${siteUrl}/#organization` },
    keywords: tags.join(', '),
    articleSection: category,
  });
}

// 8. FAQPage
if (faqs && faqs.length > 0) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${canonicalUrl}/#faq`,
    isPartOf: { '@id': `${canonicalUrl}/#webpage` },
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  });
}

// 9. Review
if (review) {
  graph.push({
    '@type': 'Review',
    '@id': `${canonicalUrl}/#review`,
    isPartOf: { '@id': `${canonicalUrl}/#webpage` },
    itemReviewed: {
      '@type': 'Thing',
      name: review.itemReviewed?.name || title,
      description: review.itemReviewed?.description,
      image: review.itemReviewed?.image ? new URL(review.itemReviewed.image, siteUrl).href : undefined,
    },
    author: {
      '@type': 'Person',
      name: review.author || author || orgData.name,
    },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: review.ratingValue,
      bestRating: review.bestRating || 5,
      worstRating: review.worstRating || 1,
    },
    datePublished: review.datePublished || publishedTime || new Date().toISOString(),
    reviewBody: review.reviewBody,
  });
}

// 10. License metadata (ImageObject enrichment)
if (license || acquireLicensePage) {
  graph.push({
    '@type': 'ImageObject',
    '@id': `${imageUrl}/#primaryimage`,
    url: imageUrl,
    license: license,
    acquireLicensePage: acquireLicensePage,
    creditText: creditText,
    copyrightNotice: copyrightNotice,
    creator: creator ? { '@type': 'Person', name: creator } : undefined,
  });
}
---

<Seo
  title={fullTitle}
  description={description}
  canonical={canonicalUrl}
  siteName={SITE_TITLE}
  ogType={(type === 'blog' || type === 'article') ? 'article' : (type === 'profile' ? 'profile' : 'website')}
  ogImage={imageUrl}
  ogImageAlt={title}
  locale={hreflangMap[lang as keyof typeof hreflangMap]}
  twitterCard="summary_large_image"
  twitterSite={SOCIAL_LINKS.X.split('/').pop()}
  twitterCreator={author}
  twitterImage={imageUrl}
  articlePublishedTime={publishedTime}
  articleModifiedTime={modifiedTime}
  articleAuthor={author ? [author] : undefined}
  noindex={noindex}
  graph={{ "@context": "https://schema.org", "@graph": graph }}
  alternates={{
    defaultLocale: 'en',
    entries: Object.entries(alternateUrls).map(([hreflang, href]) => ({ hreflang, href }))
  }}
  extraMeta={[
    { property: 'og:logo', content: orgData.logo },
    { property: 'og:image', content: imageUrl }
  ]}
/>

<FaviconLinks />
