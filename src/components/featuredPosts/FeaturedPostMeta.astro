---
import type { CollectionEntry } from 'astro:content';
import { DateService } from '../../services/DateService';
import { getLocalizedPath, slugifyTag } from '../../i18n/utils';
import { BlogService } from '../../services/BlogService';
import Avatar from '../ui/Avatar.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  lang: string;
}

const { post, lang } = Astro.props;

// Fetch author details for the avatar
const authorDetails = await BlogService.getAuthorDetails(post.data.author);
// Fallback hierarchy: Author collection avatar -> Blog post authorImage -> Default icon
const authorAvatar = authorDetails?.data.avatar || post.data.authorImage;
---

<div class="flex items-center gap-4 text-sm text-blue-100/90 sm:gap-3">
  <a
    href={getLocalizedPath(`/blog/authors/${slugifyTag(post.data.author)}`, lang)}
    class="group/author relative z-30 flex items-center gap-2.5 font-medium pointer-events-auto"
  >
    <Avatar
      src={authorAvatar}
      alt={post.data.author}
      size="sm"
      class="transition-all duration-300 group-hover/author:scale-105"
    />
    <span class="truncate transition-colors duration-300 group-hover/author:text-blue-300">
      {post.data.author}
    </span>
  </a>
  <span class="h-1 w-1 rounded-full bg-blue-200" aria-hidden="true"></span>
  <time
    datetime={new Date(post.data.pubDate).toISOString()}
    class="flex items-center gap-1.5 font-light text-blue-200/80"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      fill="none"
      class="h-[1em] w-[1em]"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
      >
      </path>
    </svg>
    {DateService.format(post.data.pubDate, lang)}
  </time>
</div>
