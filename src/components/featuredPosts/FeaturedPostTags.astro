---
import { getLocalizedPath, slugifyTag } from '@/i18n/utils';

interface Props {
  tags?: string[];
  lang?: string;
}

const { tags = [], lang = 'en' } = Astro.props;
---

{
  tags.length > 0 && (
    <div class="relative z-30 flex flex-wrap gap-2">
      {tags.slice(0, 3).map((tag: string) => (
        <a
          href={getLocalizedPath(`/blog/tags/${slugifyTag(tag)}`, lang)}
          class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium backdrop-blur-md transition-all hover:bg-white/20 hover:border-white/20 sm:px-4 sm:py-1.5 pointer-events-auto"
          aria-label={`View all posts tagged ${tag}`}
        >
          {tag}
        </a>
      ))}
    </div>
  )
}
