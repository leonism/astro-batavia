---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { BreadCrumbService } from '@/services/BreadCrumbService';
import type { LanguageKey } from '@/i18n/types';

import BlogTableOfContents from '@/components/blog/BlogTableOfContents.astro';

interface Props {
  title?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title: pageTitle, headings = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url) as LanguageKey;
const t = useTranslations(lang);
const breadcrumbs = BreadCrumbService.getBreadCrumbs(Astro.url.pathname, lang);

// Use the page title for the last breadcrumb if it's more descriptive than the slug
// Skip override if the last item is a pagination segment (e.g., "Page 2")
if (pageTitle && breadcrumbs.length > 0) {
  const lastItem = breadcrumbs[breadcrumbs.length - 1];
  const pageLabel = t('pagination.page') || 'Page';
  const isPagination = lastItem.name.includes(pageLabel) || /^\d+$/.test(lastItem.name);

  if (breadcrumbs.length > 1 && !isPagination) {
    const cleanTitle = pageTitle.split(' | ')[0].trim();
    lastItem.name = cleanTitle;
  }
}

// Don't show breadcrumbs on language roots (/es/, /ja/, etc.)
const isLanguageRoot =
  lang !== 'en' && (Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`);
const shouldShow = breadcrumbs.length > 1 && !isLanguageRoot;
---

{
  shouldShow && (
    <div class="sticky tracking-wide top-16 z-40 w-full border-b border-slate-100/95 bg-white/90 backdrop-blur-lg transition-all duration-500 animate-in fade-in slide-in-from-top-1 dark:border-slate-800/40 dark:bg-slate-900/80 dark:shadow-none">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="relative flex items-center justify-between">
          <nav
            aria-label="Breadcrumb"
            class="flex flex-1 h-11 items-center overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
          >
            <ol class="inline-flex items-center space-x-2 whitespace-nowrap font-stretch-semi-expanded py-3 sm:space-x-2">
              {breadcrumbs.map((item, index) => (
                <li class="inline-flex items-center min-w-0">
                  {index > 0 && (
                    <svg
                      class="mx-1.5 h-3 w-3 shrink-0 text-slate-300 dark:text-slate-600"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  )}

                  {item.isLast || !item.url ? (
                    <span
                      class={`flex items-center gap-1.5 px-1 py-0.5 text-xs font-medium ${
                        item.isLast
                          ? 'text-slate-400 dark:text-slate-500'
                          : 'text-slate-600 dark:text-slate-400'
                      }`}
                      title={item.isLast ? item.name : undefined}
                    >
                      {index === 0 && (
                        <svg
                          class="h-4 w-4 shrink-0 text-primary-500/80 dark:text-primary-400/80"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                          xmlns="http://www.w3.org/2000/svg"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                          />
                        </svg>
                      )}
                      {index === 0 ? <span class="sr-only">{item.name}</span> : item.name}
                    </span>
                  ) : (
                    <a
                      href={item.url}
                      class="group flex items-center gap-1.5 rounded px-1 py-0.5 text-xs font-medium text-slate-500 transition-all hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400"
                    >
                      {index === 0 && (
                        <svg
                          class="h-4 w-4 shrink-0 text-slate-400/80 transition-colors group-hover:text-primary-500/80"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                          xmlns="http://www.w3.org/2000/svg"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                          />
                        </svg>
                      )}
                      <span class="relative">
                        {index === 0 ? <span class="sr-only">{item.name}</span> : item.name}
                        <span class="absolute -bottom-0.5 left-0 h-px w-0 bg-primary-500/40 transition-all duration-300 group-hover:w-full" />
                      </span>
                    </a>
                  )}
                </li>
              ))}
            </ol>
          </nav>
          {/* Edge fade-out for scrollable breadcrumbs on mobile */}
          <div class="pointer-events-none absolute right-0 top-0 h-full w-8 bg-linear-to-l from-white/80 to-transparent dark:from-slate-900/90 sm:hidden" />

          {/* ── Mobile TOC accordion (inside breadcrumbs) ── */}
          {headings.length > 0 && (
            <div class="toc-mobile-container lg:hidden flex-none ml-2 border-l border-slate-200 dark:border-slate-700/60 pl-2">
              <BlogTableOfContents {headings} {lang} variant="mobile" />
            </div>
          )}
        </div>
      </div>
    </div>
  )
}
