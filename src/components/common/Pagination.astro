---
import { useTranslations } from '@/i18n/utils';
import type { Page } from 'astro';

interface Props {
  page: Page<any>;
  lang: string;
}

const { page, lang } = Astro.props;
const t = useTranslations(lang as any);
---

<div class="mt-16 flex justify-center border-t border-slate-100 pt-10 dark:border-slate-800">
  <nav class="flex items-center gap-2" aria-label="Pagination">
    {page.url.prev ? (
      <a
        href={page.url.prev}
        class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
      >
        ← {t('blog.previousArticle')}
      </a>
    ) : (
      <span class="cursor-not-allowed rounded-lg border border-slate-100 px-4 py-2 text-sm font-medium text-slate-300 dark:border-slate-800 dark:text-slate-600">
        ← {t('blog.previousArticle')}
      </span>
    )}

    <span class="px-4 py-2 text-sm text-slate-600 dark:text-slate-400">
      {t('blog.pagination.info')
        .replace('{current}', page.currentPage.toString())
        .replace('{total}', page.lastPage.toString())}
    </span>

    {page.url.next ? (
      <a
        href={page.url.next}
        class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
      >
        {t('blog.nextArticle')} →
      </a>
    ) : (
      <span class="cursor-not-allowed rounded-lg border border-slate-100 px-4 py-2 text-sm font-medium text-slate-300 dark:border-slate-800 dark:text-slate-600">
        {t('blog.nextArticle')} →
      </span>
    )}
  </nav>
</div>
