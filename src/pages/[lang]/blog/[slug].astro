---
import { type CollectionEntry, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import BlogPost from '@/layouts/BlogPost.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Pagination from '@/components/common/Pagination.astro';
import { useTranslations, isValidLanguage, getLocalizedPath } from '@/i18n/utils';
import { BlogService } from '@/services/BlogService';
import { PAGINATION_POSTS_PER_PAGE, LOCALES } from '@/consts';
import type { GetStaticPaths, MarkdownHeading, Page } from 'astro';

export const getStaticPaths = (async () => {
  const languages = Object.keys(LOCALES);
  const allPaths = [];

  // 1. Pagination Paths (Pages 2+)
  for (const lang of languages) {
    const locale = lang as any;
    const posts = await BlogService.getPostsByLocale(locale);
    const totalPosts = posts.length;
    const lastPage = Math.ceil(totalPosts / PAGINATION_POSTS_PER_PAGE);

    for (let currentPage = 2; currentPage <= lastPage; currentPage++) {
      const start = (currentPage - 1) * PAGINATION_POSTS_PER_PAGE;
      const end = Math.min(start + PAGINATION_POSTS_PER_PAGE, totalPosts);
      const data = posts.slice(start, end);

      allPaths.push({
        params: { lang, slug: String(currentPage) },
        props: {
          page: {
            data,
            start,
            end: end - 1,
            total: totalPosts,
            currentPage,
            size: PAGINATION_POSTS_PER_PAGE,
            lastPage,
            url: {
              current: getLocalizedPath(`/blog/${currentPage}`, locale),
              prev: currentPage === 2 
                ? getLocalizedPath('/blog', locale) 
                : getLocalizedPath(`/blog/${currentPage - 1}`, locale),
              next: currentPage < lastPage 
                ? getLocalizedPath(`/blog/${currentPage + 1}`, locale) 
                : undefined,
              first: getLocalizedPath('/blog', locale),
              last: getLocalizedPath(`/blog/${lastPage}`, locale),
            }
          }
        }
      });
    }
  }

  // 2. Individual Post Paths
  const allPosts = await BlogService.getAllPosts();
  allPosts.forEach((post) => {
    const [lang, ...slugParts] = post.id.replace(/\.mdx?$/, '').split('/');
    const postSlug = slugParts[0] === 'blog' ? slugParts.slice(1).join('/') : slugParts.join('/');
    
    // Safety check: ensure slug is not a reserved word (though it shouldn't be for 1-segment slugs)
    if (postSlug !== 'tags' && postSlug !== 'authors') {
      allPaths.push({
        params: { lang, slug: postSlug },
        props: { post },
      });
    }
  });

  return allPaths;
}) satisfies GetStaticPaths;

type Props = {
  post?: CollectionEntry<'blog'>;
  page?: Page<CollectionEntry<'blog'>>;
};

const { post, page } = Astro.props as Props;
const { lang, slug } = Astro.params;

if (!lang || !isValidLanguage(lang)) {
  return Astro.redirect('/404');
}

let Content: any;
let headings: MarkdownHeading[] = [];
let readingTime;
let readingTimeMinutes;

if (post) {
  const rendered = await render(post);
  Content = rendered.Content;
  headings = rendered.headings;
  readingTime = rendered.remarkPluginFrontmatter?.readingTime;
  readingTimeMinutes = rendered.remarkPluginFrontmatter?.readingTimeMinutes;
}

const t = useTranslations(lang);
---

{
  post ? (
    <BlogPost {...post.data} slug={post.id} headings={headings} readingTime={readingTime} readingTimeMinutes={readingTimeMinutes}>
      {Content && <Content />}
    </BlogPost>
  ) : page ? (
    <Layout
      title={`${t('nav.blog')} | ${t('pagination.page')} ${page.currentPage}`}
      description={
        lang === 'es'
          ? 'Explora nuestra colección de artículos sobre desarrollo web, tendencias tecnológicas y perspectivas.'
          : lang === 'ja'
            ? 'ウェブ開発、技術トレンド、洞察をカバーする記事のコレクションをご覧ください。'
            : 'Explore our collection of articles covering web development, technology trends, and insights.'
      }
      lang={lang}
    >
      <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        {/* Header */}
        <div class="mb-12 text-center">
          <h1 class="mb-4 text-4xl font-bold text-gray-900 dark:text-gray-100 sm:text-5xl">
            {t('nav.blog')}
          </h1>
          <p class="mx-auto max-w-3xl text-xl text-gray-600 dark:text-gray-300">
            {lang === 'es'
              ? 'Últimas noticias, tutoriales y actualizaciones de nuestro equipo'
              : lang === 'ja'
                ? 'チームからの最新ニュース、チュートリアル、アップデート'
                : 'Latest news, tutorials, and updates from our team'}
          </p>
        </div>

        {/* Blog Grid */}
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {page.data.map((p, index) => (
            <BlogCard
              post={p}
              lang={lang}
              loading={index < 3 ? 'eager' : 'lazy'}
              class="post-item animate-fade-in"
            />
          ))}
        </div>

        {/* Pagination */}
        {page.lastPage > 1 && <Pagination page={page} lang={lang} />}
      </div>
    </Layout>
  ) : (
    // Fallback/Error - Should not happen given getStaticPaths
    <div class="flex items-center justify-center min-h-[50vh]">
        <p class="text-xl text-slate-500">Post not found.</p>
    </div>
  )
}
