---
import { BlogService } from '@/services/BlogService';
import Layout from '@/layouts/Layout.astro';
import { useTranslations, getLocalizedPath, slugifyTag } from '@/i18n/utils';
import type { LanguageKey } from '@/i18n/types';

import BlogCard from '@/components/blog/BlogCard.astro';

import { LOCALES } from '@/consts';

export async function getStaticPaths() {
  return Object.keys(LOCALES).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as LanguageKey;
const t = useTranslations(locale);

// Get posts for this locale to group them
const posts = await BlogService.getPostsByLocale(locale);

// Group posts by tag
const tagsMap = new Map<string, CollectionEntry<'blog'>[]>();
posts.forEach(post => {
  (post.data.tags || []).forEach(tag => {
    const existing = tagsMap.get(tag) || [];
    existing.push(post);
    tagsMap.set(tag, existing);
  });
});

// Convert to array and sort by popularity (count)
const tagSections = Array.from(tagsMap.entries())
  .map(([tag, tagPosts]) => ({
    tag,
    posts: tagPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    count: tagPosts.length
  }))
  .sort((a, b) => b.count - a.count);
---

<Layout
  title={`${t('nav.tags')} | ${t('nav.blog')}`}
  description={locale === 'es'
    ? 'Explora todos los temas de nuestro blog por etiquetas.'
    : locale === 'ja'
      ? 'タグでブログのすべてのトピックを探索します。'
      : 'Explore all topics in our blog by tags.'}
  lang={locale}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-white sm:text-5xl">
        {t('nav.tags')}
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-slate-600 dark:text-slate-400 sm:text-xl">
        {locale === 'es'
          ? 'Encuentra artículos por tema y categoría.'
          : locale === 'ja'
            ? 'トピックやカテゴリー別に記事を見つける。'
            : 'Find articles by topic and category.'}
      </p>
    </div>

    {tagSections.length > 0 ? (
      <div class="space-y-20">
        {tagSections.map(({ tag, posts: tagPosts, count }) => (
          <section class="relative" aria-labelledby={`tag-title-${slugifyTag(tag)}`}>
            <div class="mb-8 flex items-end justify-between border-b border-slate-200 pb-4 dark:border-slate-800">
              <div class="flex items-center gap-3">
                <h2 
                  id={`tag-title-${slugifyTag(tag)}`}
                  class="text-3xl font-bold text-slate-900 dark:text-white"
                >
                  <a 
                    href={getLocalizedPath(`/blog/tags/${slugifyTag(tag)}`, locale)}
                    class="hover:text-blue-600 dark:hover:text-blue-400"
                  >
                    #{tag}
                  </a>
                </h2>
                <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                  {count} {count === 1 ? t('blog.post') : t('blog.posts')}
                </span>
              </div>
              <a 
                href={getLocalizedPath(`/blog/tags/${slugifyTag(tag)}`, locale)}
                class="text-sm font-medium text-blue-600 hover:underline dark:text-blue-400"
              >
                {t('blog.viewAll')} &rarr;
              </a>
            </div>

            <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
              {tagPosts.slice(0, 3).map((post) => (
                <BlogCard post={post} lang={locale} />
              ))}
            </div>
          </section>
        ))}
      </div>
    ) : (
      <div class="py-20 text-center">
        <p class="text-xl text-slate-500">
          {locale === 'es' ? 'No se encontraron etiquetas.' : locale === 'ja' ? 'タグが見つかりません。' : 'No tags found.'}
        </p>
      </div>
    )}
  </div>
</Layout>
