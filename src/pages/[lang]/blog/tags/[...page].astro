---
import { type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { useTranslations, getLocalizedPath, slugifyTag, isValidLanguage } from '@/i18n/utils';
import { BlogService } from '@/services/BlogService';
import { LOCALES, PAGINATION_TAGS_PER_PAGE } from '@/consts';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const languages = Object.keys(LOCALES);
  const allPaths = [];

  for (const lang of languages) {
    const locale = lang as any;
    const posts = await BlogService.getPostsByLocale(locale);
    
    // Group posts by tag
    const tagsMap = new Map<string, CollectionEntry<'blog'>[]>();
    posts.forEach(post => {
      (post.data.tags || []).forEach(tag => {
        const normalizedTag = tag.trim().normalize('NFC');
        const existing = tagsMap.get(normalizedTag) || [];
        existing.push(post);
        tagsMap.set(normalizedTag, existing);
      });
    });

    const tagSections = Array.from(tagsMap.entries())
      .map(([tag, tagPosts]) => ({
        tag,
        posts: tagPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
        count: tagPosts.length
      }))
      .sort((a, b) => b.count - a.count);

    // 1. Paginated Tag Index Paths
    const tagIndexPaths = paginate(tagSections, {
      params: { lang },
      pageSize: PAGINATION_TAGS_PER_PAGE,
    });
    
    // Adjust paths so the first page has page: undefined
    const adjustedTagIndexPaths = tagIndexPaths.map(path => {
      const pageNum = path.params.page;
      return { 
        ...path, 
        params: { ...path.params, page: pageNum === "1" ? undefined : pageNum },
        props: { ...path.props, isIndex: true }
      };
    });
    
    allPaths.push(...adjustedTagIndexPaths);

    // 2. Individual Tag Page Paths
    const uniqueTags = Array.from(tagsMap.keys());
    for (const tag of uniqueTags) {
      const tagSlug = slugifyTag(tag);
      if (tagSlug) {
        // We don't paginate posts within a tag here to keep it simple as per original [tag].astro
        allPaths.push({
          params: { lang, page: tagSlug },
          props: { tag, isIndex: false }
        });
      }
    }
  }

  return allPaths;
}) satisfies GetStaticPaths;

type Props = {
  page?: Page<{ tag: string; posts: CollectionEntry<'blog'>[]; count: number }>;
  tag?: string;
  isIndex: boolean;
};

const { page, tag, isIndex } = Astro.props;
const { lang } = Astro.params;

if (!lang || !isValidLanguage(lang)) {
  return Astro.redirect('/404');
}

const locale = lang as any;
const t = useTranslations(locale);

// Prepare data for rendering
let tagPosts: CollectionEntry<'blog'>[] = [];
if (!isIndex && tag) {
  tagPosts = await BlogService.getPostsByTag(lang, tag);
}
---

<Layout
  title={isIndex 
    ? `${t('nav.tags')} ${page && page.currentPage > 1 ? `| Page ${page.currentPage}` : ''} | ${t('nav.blog')}`
    : `#${tag} | ${t('nav.blog')}`
  }
  description={isIndex
    ? (locale === 'es' ? 'Explora todos los temas de nuestro blog por etiquetas.' : locale === 'ja' ? 'タグでブログのすべてのトピックを探索します。' : 'Explore all topics in our blog by tags.')
    : (locale === 'es' ? `Artículos sobre ${tag}` : locale === 'ja' ? `${tag}に関する記事` : `Articles about ${tag}`)
  }
  lang={locale}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    {isIndex ? (
      <>
        <div class="mb-16 text-center">
          <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-white sm:text-5xl">
            {t('nav.tags')}
          </h1>
          <p class="mx-auto max-w-2xl text-lg text-slate-600 dark:text-slate-400 sm:text-xl">
            {locale === 'es'
              ? 'Encuentra artículos por tema y categoría.'
              : locale === 'ja'
                ? 'トピックやカテゴリー別に記事を見つける。'
                : 'Find articles by topic and category.'}
          </p>
        </div>

        {page && page.data.length > 0 ? (
          <div class="space-y-20">
            {page.data.map(({ tag: tagName, posts: sectionPosts, count }) => (
              <section class="relative" aria-labelledby={`tag-title-${slugifyTag(tagName)}`}>
                <div class="mb-8 flex items-end justify-between border-b border-slate-200 pb-4 dark:border-slate-800">
                  <div class="flex items-center gap-3">
                    <h2 
                      id={`tag-title-${slugifyTag(tagName)}`}
                      class="text-3xl font-bold text-slate-900 dark:text-white"
                    >
                      <a 
                        href={getLocalizedPath(`/blog/tags/${slugifyTag(tagName)}`, locale)}
                        class="hover:text-blue-600 dark:hover:text-blue-400"
                      >
                        #{tagName}
                      </a>
                    </h2>
                    <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-semibold text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                      {count} {count === 1 ? t('blog.post') : t('blog.posts')}
                    </span>
                  </div>
                  <a 
                    href={getLocalizedPath(`/blog/tags/${slugifyTag(tagName)}`, locale)}
                    class="text-sm font-medium text-blue-600 hover:underline dark:text-blue-400"
                  >
                    {t('blog.viewTagArticles')} &rarr;
                  </a>
                </div>

                <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
                  {sectionPosts.slice(0, 3).map((post) => (
                    <BlogCard post={post} lang={locale} />
                  ))}
                </div>
              </section>
            ))}
          </div>
          
          {/* Pagination */}
          {page.lastPage > 1 && (
            <div class="mt-12 flex justify-center">
              <nav class="flex items-center gap-2" aria-label="Pagination">
                {page.url.prev ? (
                  <a
                    href={page.url.prev}
                    class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800"
                  >
                    ← {t('blog.previousArticle')}
                  </a>
                ) : (
                  <span class="cursor-not-allowed rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-400 dark:border-gray-700 dark:text-gray-500">
                    ← {t('blog.previousArticle')}
                  </span>
                )}

                <span class="px-4 py-2 text-sm text-gray-600 dark:text-gray-400">
                  Page {page.currentPage} of {page.lastPage}
                </span>

                {page.url.next ? (
                  <a
                    href={page.url.next}
                    class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800"
                  >
                    {t('blog.nextArticle')} →
                  </a>
                ) : (
                  <span class="cursor-not-allowed rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-400 dark:border-gray-700 dark:text-gray-500">
                    {t('blog.nextArticle')} →
                  </span>
                )}
              </nav>
            </div>
          )}
        ) : (
          <div class="py-20 text-center">
            <p class="text-xl text-slate-500">
              {locale === 'es' ? 'No se encontraron etiquetas.' : locale === 'ja' ? 'タグが見つかりません。' : 'No tags found.'}
            </p>
          </div>
        )}
      </>
    ) : (
      <>
        {/* Header */}
        <div class="mb-12 text-center">
          <h1 class="mb-4 text-4xl font-bold text-gray-900 dark:text-gray-100 sm:text-5xl">
            #{tag}
          </h1>
          <p class="mx-auto max-w-3xl text-xl text-gray-600 dark:text-gray-300">
            {
              locale === 'es'
                ? `Artículos etiquetados con #${tag}`
                : locale === 'ja'
                  ? `#${tag} のタグが付いた記事`
                  : `Articles tagged with #${tag}`
            }
          </p>
        </div>

        {/* Posts Grid */}
        {tagPosts.length > 0 ? (
          <div
            id="posts-container"
            class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3"
          >
            {tagPosts.map((post: CollectionEntry<'blog'>) => (
              <div class="post-item animate-fade-in">
                <BlogCard post={post} lang={locale} />
              </div>
            ))}
          </div>
        ) : (
          <div class="py-12 text-center">
            <p class="text-gray-500 dark:text-gray-400">
              {locale === 'es'
                ? 'No se encontraron artículos.'
                : locale === 'ja'
                  ? '記事が見つかりません。'
                  : 'No articles found.'}
            </p>
          </div>
        )}
      </>
    )}
  </div>
</Layout>
